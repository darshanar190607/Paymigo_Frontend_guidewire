# PayMigo Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.

# ─── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (Neon PostgreSQL / any postgres URL) ────────────
DATABASE_URL=

# ─── Firebase Admin SDK ───────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# OR use a service account JSON path:
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# ─── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Weather APIs ─────────────────────────────────────────────
ACCUWEATHER_API_KEY=
OPENWEATHER_API_KEY=

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=

# ─── AI (Groq / OpenAI) ───────────────────────────────────────
GROQ_API_KEY=
