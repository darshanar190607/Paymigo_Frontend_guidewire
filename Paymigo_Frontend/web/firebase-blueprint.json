{
  "entities": {
    "Worker": {
      "title": "Worker",
      "description": "A delivery partner registered on the platform",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the worker" },
        "phone": { "type": "string", "description": "Phone number, used for identification" },
        "city": { "type": "string", "description": "City of operation" },
        "zone": { "type": "string", "description": "Zone of operation" },
        "plan": { "type": "string", "description": "Selected plan name" },
        "isMonsoon": { "type": "boolean", "description": "Whether monsoon mode is active" },
        "weeklyPremium": { "type": "number", "description": "Weekly premium amount" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Registration timestamp" },
        "status": { "type": "string", "description": "Current status of the worker" }
      },
      "required": ["name", "phone", "city", "zone", "plan"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "Financial wallet for a worker",
      "type": "object",
      "properties": {
        "workerId": { "type": "string", "description": "ID of the worker" },
        "loyaltyPoolBalance": { "type": "number", "description": "Balance in the loyalty pool" },
        "availableBalance": { "type": "number", "description": "Balance available for withdrawal" },
        "premiumReserve": { "type": "number", "description": "Reserve for future premiums" },
        "totalEarned": { "type": "number", "description": "Total earnings since start" },
        "totalWithdrawn": { "type": "number", "description": "Total amount withdrawn" }
      },
      "required": ["workerId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction record",
      "type": "object",
      "properties": {
        "workerId": { "type": "string", "description": "ID of the worker" },
        "type": { "type": "string", "enum": ["CREDIT", "DEBIT"], "description": "Transaction type" },
        "amount": { "type": "number", "description": "Transaction amount" },
        "description": { "type": "string", "description": "Description of the transaction" },
        "balanceAfter": { "type": "number", "description": "Wallet balance after transaction" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Transaction timestamp" }
      },
      "required": ["workerId", "type", "amount", "balanceAfter"]
    },
    "Claim": {
      "title": "Claim",
      "description": "An insurance claim submitted by a worker",
      "type": "object",
      "properties": {
        "workerId": { "type": "string", "description": "ID of the worker" },
        "workerName": { "type": "string", "description": "Name of the worker" },
        "type": { "type": "string", "description": "Type of claim (e.g., Income Protection)" },
        "description": { "type": "string", "description": "Detailed description of the claim" },
        "statement": { "type": "string", "description": "Legible statement provided for the claim" },
        "amount": { "type": "number", "description": "Claimed amount" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"], "description": "Current status of the claim" },
        "adminComment": { "type": "string", "description": "Comment from the admin after review" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["workerId", "type", "description", "statement", "amount", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a worker",
      "type": "object",
      "properties": {
        "workerId": { "type": "string", "description": "ID of the worker" },
        "title": { "type": "string", "description": "Title of the notification" },
        "message": { "type": "string", "description": "Message content" },
        "type": { "type": "string", "enum": ["INFO", "SUCCESS", "WARNING", "DANGER"], "description": "Notification type" },
        "read": { "type": "boolean", "description": "Whether the notification has been read" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Notification timestamp" }
      },
      "required": ["workerId", "title", "message", "type", "read"]
    }
  },
  "firestore": {
    "workers": {
      "schema": "Worker",
      "description": "Collection of delivery workers"
    },
    "wallets": {
      "schema": "Wallet",
      "description": "Collection of worker wallets"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Collection of financial transactions"
    },
    "claims": {
      "schema": "Claim",
      "description": "Collection of insurance claims"
    },
    "notifications": {
      "schema": "Notification",
      "description": "Collection of worker notifications"
    }
  }
}
